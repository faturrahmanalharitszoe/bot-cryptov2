# ========================
# Bot-CryptoV2 Environment Variables
# ========================

# Binance API (Testnet)
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret_here

# Binance API (Live — use with extreme caution)
BINANCE_LIVE_API_KEY=your_live_api_key_here
BINANCE_LIVE_API_SECRET=your_live_api_secret_here

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# CryptoPanic API (optional — for news sentiment)
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key

# GPU Settings
CUDA_VISIBLE_DEVICES=0
